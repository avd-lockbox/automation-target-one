{
  "name": "automation-target-one",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "yarn@4.9.2",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:dry": "node esbuild.config.mjs --dry-run",
    "lint": "eslint src tests",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": ["eslint --fix", "prettier --write"],
    "*.{js,mjs,cjs,json,md}": ["prettier --write"]
  },
  "devDependencies": {
    "@lockbox/eslint-config": "^0.1.0",
    "@lockbox/prettier-config": "^0.1.0",
    "@lockbox/tsconfig": "^0.1.0",
    "@lockbox/commitlint-config": "^0.1.0",
    "@lockbox/lefthook-config": "^0.1.0",
    "@commitlint/cli": "^19.0.0",
    "@vitest/eslint-plugin": "^1.0.0",
    "eslint": "^9.0.0",
    "lefthook": "^1.6.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "@playwright/test": "^1.50.0",
    "esbuild": "^0.24.0"
  }
}
